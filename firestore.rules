rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────
    // HELPER FUNCTIONS
    // ───────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() in ['admin', 'president', 'vice_president'];
    }

    function isCoordinator() {
      return isSignedIn() && getUserRole() in [
        'admin', 'president', 'vice_president',
        'girls_coordinator', 'boys_coordinator',
        'coach_coordinator', 'youth_head_coach'
      ];
    }

    function isCoach() {
      return isSignedIn() && getUserRole() in [
        'admin', 'president', 'vice_president',
        'girls_coordinator', 'boys_coordinator',
        'coach_coordinator', 'youth_head_coach',
        'coach', 'youth_coach'
      ];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ───────────────────────────────────────
    // USERS
    // ───────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['role', 'disabled', 'deleted', 'deletedAt', 'deletedBy', 'disabledAt', 'disabledBy']
        ));
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    // ───────────────────────────────────────
    // PLAYERS
    // ───────────────────────────────────────
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // TEAMS
    // ───────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create, update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // EVALUATIONS
    // ───────────────────────────────────────
    match /evaluations/{evalId} {
      allow read: if isSignedIn();
      allow create: if isCoach();
      allow update: if isCoach() && resource.data.coachId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // MATCH ASSESSMENTS
    // ───────────────────────────────────────
    match /match_assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow create: if isCoach();
      allow update: if isCoach() && resource.data.coachId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // TRYOUT SESSIONS
    // ───────────────────────────────────────
    match /tryout_sessions/{sessionId} {
      allow read: if isCoordinator();
      allow read: if isSignedIn()
        && getUserRole() == 'tryout_assessor'
        && request.auth.uid in resource.data.assessors;
      allow create, update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // TRYOUT ASSESSMENTS
    // ───────────────────────────────────────
    match /tryout_assessments/{assessmentId} {
      allow read: if isCoordinator();
      allow read: if isSignedIn() && resource.data.assessorId == request.auth.uid;
      allow create: if isSignedIn()
        && getUserRole() in ['tryout_assessor', 'coach', 'admin',
          'president', 'vice_president', 'girls_coordinator',
          'boys_coordinator', 'coach_coordinator'];
      allow update: if isSignedIn() && resource.data.assessorId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // TRYOUT EVALUATIONS
    // ───────────────────────────────────────
    match /tryout_evaluations/{evalId} {
      allow read: if isCoordinator();
      allow read: if isSignedIn() && resource.data.assessorId == request.auth.uid;
      allow create: if isSignedIn()
        && getUserRole() in ['tryout_assessor', 'coach', 'admin',
          'president', 'vice_president', 'girls_coordinator',
          'boys_coordinator', 'coach_coordinator'];
      allow update: if isSignedIn() && resource.data.assessorId == request.auth.uid;
      allow update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // TRAINING PLANS
    // ───────────────────────────────────────
    match /training_plans/{planId} {
      allow read: if isCoach();
      allow create: if isCoach();
      allow update: if isCoach() && resource.data.coachId == request.auth.uid;
      allow update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // DRILLS LIBRARY
    // ───────────────────────────────────────
    match /drills/{drillId} {
      allow read: if isCoach();
      allow create: if isCoach();
      allow update: if isCoach()
        && (resource.data.createdBy == request.auth.uid || isCoordinator());
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // INDIVIDUAL DEVELOPMENT PLANS
    // ───────────────────────────────────────
    match /development_plans/{planId} {
      allow read: if isCoach();
      allow read: if isSignedIn()
        && getUserRole() == 'parent'
        && request.auth.uid in resource.data.parentIds;
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // ATTENDANCE
    // ───────────────────────────────────────
    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // SCHEDULE / FIXTURES
    // ───────────────────────────────────────
    match /schedule/{scheduleId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // GAMES
    // ───────────────────────────────────────
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // GAME RESULTS
    // ───────────────────────────────────────
    match /game_results/{gameId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // PLAYING TIME / ROTATIONS
    // ───────────────────────────────────────
    match /playing_time/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // NOTIFICATIONS
    // ───────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // SWAP REQUESTS
    // ───────────────────────────────────────
    match /swap_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (resource.data.requestingParentId == request.auth.uid
            || resource.data.targetParentId == request.auth.uid
            || isCoordinator());
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // SCORING ROSTER
    // ───────────────────────────────────────
    match /scoring_roster/{entryId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach() || isCoordinator();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // SCORING ASSIGNMENTS
    // ───────────────────────────────────────
    match /scoring_assignments/{entryId} {
      allow read: if isSignedIn();
      allow create: if isCoordinator();
      allow update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // PARENT INVITATIONS
    // ───────────────────────────────────────
    match /parent_invitations/{invitationId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // YOUTH PROGRAMS
    // ───────────────────────────────────────
    match /youth_programs/{programId} {
      allow read: if isSignedIn();
      allow create, update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // YOUTH ACHIEVEMENTS
    // ───────────────────────────────────────
    match /youth_achievements/{achievementId} {
      allow read: if isSignedIn();
      allow create, update: if isCoach();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // COACH ACCREDITATIONS
    // ───────────────────────────────────────
    match /coach_accreditations/{accredId} {
      allow read: if isSignedIn();
      allow create: if isCoach() || isAdmin();
      allow update: if isCoach() && resource.data.coachId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // ASSESSMENT METRICS
    // ───────────────────────────────────────
    match /assessment_metrics/{ageGroupId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────
    // AUDIT LOGS — IMMUTABLE
    // ───────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ───────────────────────────────────────
    // CATCH-ALL: DENY EVERYTHING ELSE
    // ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
