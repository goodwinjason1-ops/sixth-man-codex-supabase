rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────
    // Helper functions
    // ───────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isLeadership() {
      return isSignedIn() && getUserData().role in ['admin', 'president', 'vice_president'];
    }

    function isCoach() {
      return isSignedIn() && getUserData().role in ['coach', 'admin', 'president', 'vice_president'];
    }

    function isParent() {
      return hasRole('parent');
    }

    function isTeamManager() {
      return hasRole('team_manager');
    }

    // Can view tryout results: leadership + coordinators + youth head coach
    function canViewTryoutResults() {
      return isSignedIn() && getUserData().role in ['admin', 'president', 'vice_president', 'girls_coordinator', 'boys_coordinator', 'youth_head_coach'];
    }

    // Can assess tryouts: leadership, coaches, team managers, tryout assessors
    function canAssessTryouts() {
      return isSignedIn() && getUserData().role in ['admin', 'president', 'vice_president', 'coach', 'team_manager', 'tryout_assessor'];
    }

    // Validate that a role field is one of the allowed values
    function isValidRole(role) {
      return role in ['admin', 'president', 'vice_president', 'girls_coordinator', 'boys_coordinator', 'youth_head_coach', 'coach', 'youth_coach', 'tryout_assessor', 'team_manager', 'player', 'parent'];
    }

    // ───────────────────────────────────────
    // Users collection
    // ───────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId)
        && request.resource.data.keys().hasAll(['email', 'role', 'createdAt'])
        && isValidRole(request.resource.data.role)
        // Prevent self-assigning privileged roles on signup
        && !(request.resource.data.role in ['admin', 'president', 'vice_president', 'girls_coordinator', 'boys_coordinator', 'youth_head_coach', 'tryout_assessor']);
      allow update: if isSignedIn() && (isOwner(userId) || isLeadership())
        // Non-leadership cannot change their own role
        && (isLeadership() || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Teams collection
    // ───────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isLeadership();
      allow update: if isLeadership() || (isCoach() && resource.data.coachId == request.auth.uid);
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Players collection
    // ───────────────────────────────────────
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isCoach() || isLeadership();
      allow update: if isCoach() || isLeadership();
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Curriculum/Skills collection
    // ───────────────────────────────────────
    match /curriculum/{skillId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ───────────────────────────────────────
    // Evaluations collection
    // ───────────────────────────────────────
    match /evaluations/{evaluationId} {
      allow read: if isSignedIn();
      allow create: if isCoach();
      allow update: if isCoach();
      allow delete: if isCoach();
    }

    // ───────────────────────────────────────
    // Games collection
    // ───────────────────────────────────────
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ───────────────────────────────────────
    // Attendance collection
    // ───────────────────────────────────────
    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ───────────────────────────────────────
    // Training notes collection
    // ───────────────────────────────────────
    match /training_notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ───────────────────────────────────────
    // Schedule collection
    // ───────────────────────────────────────
    match /schedule/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    // ───────────────────────────────────────
    // Notifications collection
    // ───────────────────────────────────────
    match /notifications/{notificationId} {
      // Recipients can read their own; leadership can read all
      allow read: if isSignedIn()
        && (resource.data.recipientId == request.auth.uid || isLeadership());
      allow create: if isCoach() || isLeadership();
      // Recipients can mark as read; leadership can manage
      allow update: if isSignedIn()
        && (resource.data.recipientId == request.auth.uid || isLeadership());
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Scoring assignments collection
    // ───────────────────────────────────────
    match /scoring_assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create: if isLeadership();
      allow update: if isLeadership()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Swap requests collection
    // ───────────────────────────────────────
    match /swap_requests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.requesterId == request.auth.uid
            || resource.data.targetUserId == request.auth.uid
            || isLeadership());
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (resource.data.requesterId == request.auth.uid
            || resource.data.targetUserId == request.auth.uid
            || isLeadership());
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Tryout sessions collection
    // ───────────────────────────────────────
    match /tryout_sessions/{sessionId} {
      allow read: if isSignedIn() && (canAssessTryouts() || canViewTryoutResults());
      allow create: if isLeadership();
      allow update: if canAssessTryouts();
      allow delete: if isLeadership();

      // Tryout evaluations sub-collection
      match /evaluations/{evalId} {
        allow read: if isSignedIn() && (canAssessTryouts() || canViewTryoutResults());
        allow create: if canAssessTryouts();
        allow update: if canAssessTryouts();
        allow delete: if isLeadership();
      }
    }

    // ───────────────────────────────────────
    // Youth programs collection
    // ───────────────────────────────────────
    match /youth_programs/{programId} {
      allow read: if isSignedIn();
      allow create: if isLeadership();
      allow update: if isCoach() || isLeadership();
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Training plans collection
    // ───────────────────────────────────────
    match /training_plans/{planId} {
      allow read: if isSignedIn();
      allow create: if isCoach();
      allow update: if isCoach();
      allow delete: if isCoach();
    }

    // ───────────────────────────────────────
    // Audit logs collection — immutable
    // ───────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isLeadership();
      allow create: if isSignedIn();
      allow update, delete: if false; // Logs are immutable
    }

    // ───────────────────────────────────────
    // Parent invitations collection
    // ───────────────────────────────────────
    match /parent_invitations/{invitationId} {
      // Public read so unauthenticated parents can validate their invitation code
      allow read: if true;
      // Leadership and coaches can create invitations
      allow create: if isCoach();
      allow update: if isCoach()
        || (isSignedIn() && resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedBy == request.auth.uid);
      allow delete: if isLeadership();
    }

    // ───────────────────────────────────────
    // Deny-all fallback for unknown collections
    // ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
