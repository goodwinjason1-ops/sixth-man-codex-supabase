# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: bucket used by the Firebase Storage compatibility adapter.
# Create this bucket in Supabase Storage if you use screenshot feedback uploads.
VITE_SUPABASE_STORAGE_BUCKET=feedback-screenshots

# Optional override. By default the app uses:
# ${VITE_SUPABASE_URL}/functions/v1/voice-transcription
# Keep provider API keys server-side; do not expose them in the Vite client.
VITE_VOICE_TRANSCRIPTION_ENDPOINT=

# Legacy Firebase variables are no longer used by the app runtime.

# Local-only deterministic video AI adapter for development.
# These are not Vite client variables; set them in the shell that runs the adapter.
# VIDEO_AI_ADAPTER_PORT=8788
# VIDEO_AI_ADAPTER_TOKEN=local-dev-token
# VIDEO_AI_ADAPTER_NAME=open-source-shot-mvp
# VIDEO_AI_ADAPTER_MODEL=deterministic-adapter-smoke
# VIDEO_AI_ALLOW_SMOKE_FALLBACK=false

# Optional frame sampling for the external video AI adapter.
# Requires FFmpeg to be installed on the machine/container running the adapter.
# VIDEO_AI_ENABLE_FFMPEG=true
# VIDEO_AI_FFMPEG_PATH=ffmpeg
# VIDEO_AI_SAMPLE_FPS=0.5
# VIDEO_AI_MAX_FRAMES=12

# Optional Roboflow Hosted API detector for sampled frames.
# Use either ROBOFLOW_MODEL_ID or the full ROBOFLOW_INFER_ENDPOINT.
# ROBOFLOW_API_KEY=your_server_side_roboflow_key
# ROBOFLOW_MODEL_ID=your-project-slug/1
# ROBOFLOW_INFER_ENDPOINT=https://detect.roboflow.com/your-project-slug/1
# ROBOFLOW_CONFIDENCE=35
# ROBOFLOW_OVERLAP=20
# ROBOFLOW_CLASSES=ball,basketball,rim,hoop,backboard

# Supabase Edge Function secrets for video analysis.
# Configure these with `supabase secrets set ...`, not in client-side Vite builds.
# VIDEO_ANALYSIS_ENDPOINT=https://your-adapter.example.com/analyze
# VIDEO_ANALYSIS_TOKEN=shared-provider-token
# VIDEO_SIGNED_URL_TTL_SECONDS=900
