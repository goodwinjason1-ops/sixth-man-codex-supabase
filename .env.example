# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: bucket used by the Firebase Storage compatibility adapter.
# Create this bucket in Supabase Storage if you use screenshot feedback uploads.
VITE_SUPABASE_STORAGE_BUCKET=feedback-screenshots

# Optional: HTTPS endpoint that accepts multipart audio and returns { transcript }.
# Keep provider API keys server-side; do not expose them in the Vite client.
VITE_VOICE_TRANSCRIPTION_ENDPOINT=

# Legacy Firebase variables are no longer used by the app runtime.
